# Supabase 公共 API 密钥
# 用于前端直接调用 Supabase API，包含可公开的匿名密钥
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# 数据库连接池 URL (Supavisor)
# 用于 Next.js 应用运行时连接，支持高并发连接池
# 格式: postgres://[user]:[password]@[host]:6543/[db]?pgbouncer=true
DATABASE_URL="postgres://postgres.[project-ref]:[password]@aws-0-us-west-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# 数据库直连 URL
# 用于 Prisma 迁移 (migrate) 和数据库结构同步，必须直连数据库端口 5432
# 格式: postgresql://[user]:[password]@[host]:5432/[db]
DIRECT_URL="postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres"
