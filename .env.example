# -----------------------------------------------------------------------------
# 1. Supabase 客户端配置 (HTTP API)
# -----------------------------------------------------------------------------
# 作用: 给前端/服务端 SDK (@supabase/supabase-js) 使用
# 方式: 通过 HTTP 协议调用 Supabase 的 REST API (Auth, Storage, Realtime)
# 注意: 受数据库 RLS (行级安全策略) 限制，适合处理用户登录、文件上传等
NEXT_PUBLIC_SUPABASE_URL=your_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# -----------------------------------------------------------------------------
# 2. Prisma 数据库连接配置 (TCP/PostgreSQL)
# -----------------------------------------------------------------------------
# 作用: 给服务端 ORM (@prisma/client) 使用
# 方式: 通过 TCP 协议直接连接数据库，进行复杂的 SQL 查询和数据操作
# 区别: Supabase SDK 走 HTTP 接口，Prisma 走数据库 TCP 连接

# [连接池模式] 端口 6543 (Transaction Mode)
# 场景: Next.js 生产环境、Serverless 函数 (避免连接数耗尽)
# 格式: postgres://[user]:[password]@[host]:6543/[db]?pgbouncer=true
DATABASE_URL="postgres://postgres.[project-ref]:[password]@aws-0-us-west-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# [直连模式] 端口 5432 (Session Mode)
# 场景: 执行 prisma db push / migrate (需要修改表结构，必须直连)
# 格式: postgresql://[user]:[password]@[host]:5432/[db]
DIRECT_URL="postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres"
