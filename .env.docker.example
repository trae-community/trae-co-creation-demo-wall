# Database (Docker Compose 内部连接)
DATABASE_URL="postgresql://postgres:postgres@db:5432/trae_demo_wall?schema=public&connection_limit=10&pool_timeout=20"

# Redis (Docker Compose 内部连接)
REDIS_URL="redis://redis:6379"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-here-change-in-production"

# 文件上传 (使用国内对象存储)
# 七牛云示例
QINIU_ACCESS_KEY="your-qiniu-access-key"
QINIU_SECRET_KEY="your-qiniu-secret-key"
QINIU_BUCKET="your-bucket-name"
QINIU_DOMAIN="your-cdn-domain.com"

# 或使用阿里云 OSS
# ALIYUN_ACCESS_KEY_ID="your-aliyun-access-key"
# ALIYUN_ACCESS_KEY_SECRET="your-aliyun-secret-key"
# ALIYUN_OSS_BUCKET="your-bucket-name"
# ALIYUN_OSS_REGION="oss-cn-hangzhou"
# ALIYUN_OSS_DOMAIN="your-cdn-domain.com"

# Node 环境
NODE_ENV="production"
