# -----------------------------------------------------------------------------
# 1. Supabase 客户端配置 (HTTP API)
# -----------------------------------------------------------------------------
# 作用: 给前端/服务端 SDK (@supabase/supabase-js) 使用
# 方式: 通过 HTTP 协议调用 Supabase 的 REST API (Auth, Storage, Realtime)
# 注意: 受数据库 RLS (行级安全策略) 限制，适合处理用户登录、文件上传等
NEXT_PUBLIC_SUPABASE_URL=https://panfhpazkfhuohnjjuiz.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InBhbmZocGF6a2ZodW9obmpqdWl6Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzIyNTg4OTAsImV4cCI6MjA4NzgzNDg5MH0.p2NNoXqXzxPysURfq9WhG_cmE4rxbThbUaHSGmETa-g

# -----------------------------------------------------------------------------
# 2. Prisma 数据库连接配置 (TCP/PostgreSQL)
# -----------------------------------------------------------------------------
# 作用: 给服务端 ORM (@prisma/client) 使用
# 方式: 通过 TCP 协议直接连接数据库，进行复杂的 SQL 查询和数据操作
# 区别: Supabase SDK 走 HTTP 接口，Prisma 走数据库 TCP 连接

# [连接池模式] 端口 6543 (Transaction Mode)
# 场景: Next.js 生产环境、Serverless 函数 (避免连接数耗尽)
# 格式: postgres://[user]:[password]@[host]:6543/[db]?pgbouncer=true
DATABASE_URL="postgres://postgres.panfhpazkfhuohnjjuiz:TraeDemoWall@aws-1-ap-northeast-2.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# [直连模式] 端口 5432 (Session Mode)
# 场景: 执行 prisma db push / migrate (需要修改表结构，必须直连)
# 格式: postgresql://[user]:[password]@[host]:5432/[db]
# 注意: 这里使用 Supavisor Session Mode (aws-1-ap-northeast-2.pooler.supabase.com:5432) 以解决部分网络直连 db.xxx 域名失败的问题
# 用户名格式需要改为: postgres.[project-ref]
DIRECT_URL="postgresql://postgres.panfhpazkfhuohnjjuiz:TraeDemoWall@aws-1-ap-northeast-2.pooler.supabase.com:5432/postgres"

# -----------------------------------------------------------------------------
# 3. Clerk 身份验证配置
# -----------------------------------------------------------------------------
# 作用: 用于用户身份验证和会话管理
# 获取方式: 登录 Clerk Dashboard (https://dashboard.clerk.com/) -> API Keys
# 注意: NEXT_PUBLIC_ 前缀的变量会暴露给前端，SECRET_KEY 仅限服务端使用

# [必填] Clerk 发布密钥 (前端使用)
# 格式: pk_test_... (开发环境) 或 pk_live_... (生产环境)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_aW5jbHVkZWQtd3Jlbi00My5jbGVyay5hY2NvdW50cy5kZXYk

# [必填] Clerk 密钥 (服务端使用)
# 格式: sk_test_... (开发环境) 或 sk_live_... (生产环境)
# 警告: 绝对不要将此密钥提交到代码仓库或暴露给前端
CLERK_SECRET_KEY=sk_test_LuxE6kxUBLwnOYIwdAZEHALw4uHwJxEd0h0sbfL3xC
CLERK_WEBHOOK_SECRET=whsec_Lmi0+U2EELonpfoEzneOKrEVfqb6W+X8

# [可选] 登录/注册相关的路径配置
# 用于指定 Clerk 组件的默认跳转行为
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/api/auth/callback
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/api/auth/callback
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/sync
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/sync